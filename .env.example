# OpenAI API Key for GPT-based summarization
OPENAI_API_KEY=your_api_key_here

# Anthropic API Key for Claude models
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs API Key for cloud transcription (optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# OpenRouter API Key for additional models (optional)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Model selection
SUMMARY_MODEL=gpt-4o-mini
WHISPER_MODEL=base

# Whisper model cache location (defaults to E:/Coding/WhisperCache)
WHISPER_CACHE_DIR=E:/Coding/WhisperCache
